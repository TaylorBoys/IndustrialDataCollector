<Window x:Class="WpfApp.DataPointEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="编辑数据点" Height="480" Width="450"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Style="{StaticResource ModernWindow}">
    <Border Style="{StaticResource CardBorder}" Margin="20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="名称:" FontSize="14" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,8"/>
            <TextBox Grid.Row="1" x:Name="NameTextBox" Style="{StaticResource ModernTextBox}"/>

            <TextBlock Grid.Row="2" Text="地址:" FontSize="14" Foreground="{StaticResource TextPrimary}" Margin="0,20,0,8"/>
            <TextBox Grid.Row="3" x:Name="AddressTextBox" Style="{StaticResource ModernTextBox}"/>

            <TextBlock Grid.Row="4" Text="数据类型:" FontSize="14" Foreground="{StaticResource TextPrimary}" Margin="0,20,0,8"/>
            <ComboBox Grid.Row="5" x:Name="DataTypeComboBox" Style="{StaticResource ModernComboBox}"/>

            <TextBlock Grid.Row="6" Text="单位:" FontSize="14" Foreground="{StaticResource TextPrimary}" Margin="0,20,0,8"/>
            <TextBox Grid.Row="7" x:Name="UnitTextBox" Style="{StaticResource ModernTextBox}"/>

            <StackPanel Grid.Row="9" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,30,0,0">
                <Button Content="取消" Click="CancelButton_Click" Style="{StaticResource SecondaryButton}" Margin="0,0,12,0"/>
                <Button Content="确定" Click="OKButton_Click" Style="{StaticResource PrimaryButton}"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
