<Window x:Class="WpfApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="工业数据采集系统" Height="750" Width="1200"
        WindowStartupLocation="CenterScreen"
        Style="{StaticResource ModernWindow}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
            <TextBlock Text="工业数据采集系统" FontSize="30" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,30,0" VerticalAlignment="Center"/>
            <Button Content="添加设备" Command="{Binding AddDeviceCommand}" Style="{StaticResource PrimaryButton}" Margin="0,0,12,0"/>
            <Button Content="编辑设备" Command="{Binding EditDeviceCommand}" Style="{StaticResource SecondaryButton}" Margin="0,0,12,0"/>
            <Button Content="删除设备" Command="{Binding DeleteDeviceCommand}" Style="{StaticResource DangerButton}" Margin="0,0,12,0"/>
            <Button Content="数据点管理" Command="{Binding ManageDataPointsCommand}" Style="{StaticResource InfoButton}" Margin="0,0,12,0"/>
            <Button Content="启动所有" Command="{Binding StartAllCommand}" Style="{StaticResource SuccessButton}" Margin="0,0,12,0"/>
            <Button Content="停止所有" Command="{Binding StopAllCommand}" Style="{StaticResource WarningButton}"/>
        </StackPanel>
        
        <TextBlock Grid.Row="1" Text="设备列表" FontWeight="SemiBold" FontSize="18" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12"/>
        
        <DataGrid Grid.Row="2" ItemsSource="{Binding Devices}" SelectedItem="{Binding SelectedDevice}"
                  Style="{StaticResource ModernDataGrid}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="设备名称" Binding="{Binding Name}" Width="180"/>
                <DataGridTextColumn Header="协议类型" Binding="{Binding Protocol, Converter={StaticResource ProtocolTypeToChineseConverter}}" Width="130"/>
                <DataGridTextColumn Header="IP地址" Binding="{Binding IpAddress}" Width="150"/>
                <DataGridTemplateColumn Header="连接状态" Width="140">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Ellipse Width="12" Height="12" Fill="{Binding IsConnected, Converter={StaticResource BooleanToColorConverter}}" Margin="0,0,8,0"/>
                                <TextBlock Text="{Binding IsConnected, Converter={StaticResource BooleanToStatusConverter}}" Foreground="{StaticResource TextSecondaryBrush}"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="扫描状态" Width="140">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Ellipse Width="12" Height="12" Fill="{Binding IsScanning, Converter={StaticResource BooleanToColorConverter}}" Margin="0,0,8,0"/>
                                <TextBlock Text="{Binding IsScanning, Converter={StaticResource BooleanToStatusConverter}}" Foreground="{StaticResource TextSecondaryBrush}"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="最后更新" Binding="{Binding LastUpdate, StringFormat='yyyy-MM-dd HH:mm:ss'}" Width="160"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
